# =====================================================================
# Terraform working directories
# =====================================================================
.terraform/
**/.terraform/*

# =====================================================================
# Terraform state files (never commit these)
# =====================================================================
terraform.tfstate
terraform.tfstate.*
*.tfstate
*.tfstate.*

# Plans (opzionale: ignorare i file .tfplan)
*.tfplan

# =====================================================================
# Terraform lock file
# Comment this line if you want to commit the lockfile for consistency
# =====================================================================
.terraform.lock.hcl

# =====================================================================
# Sensitive variables (NEVER commit .tfvars)
# =====================================================================
*.tfvars
*.tfvars.json

# =====================================================================
# Crash logs
# =====================================================================
crash.log

# =====================================================================
# Local override files
# =====================================================================
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# =====================================================================
# Terraform CLI config files
# =====================================================================
.terraformrc
terraform.rc

# =====================================================================
# System / OS generated files
# =====================================================================
.DS_Store
Thumbs.db

# =====================================================================
# IDE / editor folders
# =====================================================================
.vscode/
.idea/

# =====================================================================
# Project-specific temporary folders
# =====================================================================
eks-easy-config/
VODAFONE-TERRAFORM/