# =====================================================================
# Terraform directories created during init/apply
# =====================================================================
**/.terraform/
**/.terraform/*

# =====================================================================
# Terraform state files (mai versionarli, contengono dati sensibili)
# =====================================================================
*.tfstate
*.tfstate.*
*.tfplan

# =====================================================================
# Terraform lock file (ignoralo se non vuoi versionarlo)
# Se vuoi mantenerlo nel repo, commenta la riga sotto
# =====================================================================
.terraform.lock.hcl

# =====================================================================
# Variabili (contengono credenziali e dati sensibili)
# =====================================================================
*.tfvars
*.tfvars.json

# =====================================================================
# Crash log
# =====================================================================
crash.log

# =====================================================================
# Override files locali
# =====================================================================
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# =====================================================================
# CLI config files
# =====================================================================
.terraformrc
terraform.rc

# =====================================================================
# Se hai cartelle generate (come quella vecchia del tuo progetto)
# =====================================================================
eks-easy-config/